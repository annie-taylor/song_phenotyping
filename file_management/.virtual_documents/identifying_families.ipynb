def visualize_detection_comparison(audio_file, save_path=None):
    """Compare derivative vs amplitude thresholding methods"""
    from tools.audio_utils import read_audio_file

    audio, fs = read_audio_file(audio_file)

    # Get smoothed signal
    smooth = smooth_data_matlab_style(audio, fs)

    # Method 1: Derivative-based
    onsets1, offsets1 = detect_syllables_matlab_style_fixed(audio, fs, threshold=0.0005)
    bouts1 = find_song_bouts(onsets1, offsets1)

    # Method 2: Amplitude threshold
    onsets2, offsets2 = detect_syllables_amplitude_threshold(audio, fs, threshold_percentile=25)
    bouts2 = find_song_bouts(onsets2, offsets2)

    # Time axes
    audio_time = np.arange(len(audio)) / fs
    smooth_time = np.arange(len(smooth)) / fs

    # Create figure
    fig, axes = plt.subplots(4, 1, figsize=(16, 12))

    # 1. Raw audio
    axes[0].plot(audio_time, audio, 'b-', alpha=0.7)
    axes[0].set_ylabel('Amplitude')
    axes[0].set_title(f'Raw Audio: {os.path.basename(audio_file)}')
    axes[0].grid(True, alpha=0.3)

    # 2. Smoothed signal with amplitude threshold
    axes[1].plot(smooth_time, smooth, 'k-', linewidth=1)
    amp_threshold = np.percentile(smooth, 25)
    axes[1].axhline(y=amp_threshold, color='red', linestyle='--',
                   label=f'Amplitude Threshold (25th percentile): {amp_threshold:.6f}')
    axes[1].set_ylabel('Smoothed Power')
    axes[1].set_title('Method 2: Amplitude Thresholding')
    axes[1].legend()
    axes[1].grid(True, alpha=0.3)

    # Mark amplitude method detections
    for onset, offset in zip(onsets2/1000, offsets2/1000):
        axes[1].axvspan(onset, offset, alpha=0.3, color='blue')
    for start, end in bouts2:
        axes[1].axvspan(start/1000, end/1000, alpha=0.15, color='green')

    # 3. Derivative signal with derivative threshold
    diff_smooth = np.abs(np.diff(smooth))
    diff_time = smooth_time[:-1]
    axes[2].plot(diff_time, diff_smooth, 'g-', linewidth=1)
    deriv_threshold = 0.0005
    axes[2].axhline(y=deriv_threshold, color='red', linestyle='--',
                   label=f'Derivative Threshold: {deriv_threshold}')
    axes[2].set_ylabel('|d(smooth)/dt|')
    axes[2].set_title('Method 1: Derivative Thresholding')
    axes[2].legend()
    axes[2].grid(True, alpha=0.3)

    # Mark derivative method detections
    for onset, offset in zip(onsets1/1000, offsets1/1000):
        axes[2].axvspan(onset, offset, alpha=0.3, color='orange')
    for start, end in bouts1:
        axes[2].axvspan(start/1000, end/1000, alpha=0.15, color='green')

    # 4. Comparison overlay
    axes[3].plot(audio_time, audio, 'b-', alpha=0.5, label='Audio')
    axes[3].set_ylabel('Amplitude')
    axes[3].set_xlabel('Time (s)')
    axes[3].set_title('Detection Comparison')

    # Method 1 (derivative) - orange
    for onset, offset in zip(onsets1/1000, offsets1/1000):
        axes[3].axvspan(onset, offset, alpha=0.4, color='orange',
                       label='Derivative Method' if onset == onsets1[0]/1000 else "")

    # Method 2 (amplitude) - blue
    for onset, offset in zip(onsets2/1000, offsets2/1000):
        axes[3].axvspan(onset, offset, alpha=0.4, color='blue',
                       label='Amplitude Method' if onset == onsets2[0]/1000 else "")

    axes[3].legend()
    axes[3].grid(True, alpha=0.3)

    # Add summary text
    summary_text = f"""Detection Summary:
    Derivative Method: {len(onsets1)} syllables, {len(bouts1)} song bouts
    Amplitude Method:  {len(onsets2)} syllables, {len(bouts2)} song bouts"""

    fig.text(0.02, 0.02, summary_text, fontsize=10,
             bbox=dict(boxstyle="round,pad=0.3", facecolor="lightgray"))

    plt.tight_layout()
    plt.subplots_adjust(bottom=0.15)  # make room for summary

    if save_path:
        plt.savefig(save_path, dpi=150, bbox_inches='tight')
        print(f"Comparison plot saved to: {save_path}")
    else:
        plt.savefig('detection_method_comparison.png', dpi=150, bbox_inches='tight')
        print("Comparison plot saved to: detection_method_comparison.png")

    plt.close()

    return (onsets1, offsets1, bouts1), (onsets2, offsets2, bouts2)

