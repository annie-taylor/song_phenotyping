import pandas as pd

def make_father_pair_summary(all_birds_df, found_birds):
    df = all_birds_df.copy()
    found_set = set(found_birds)

    df = df[
        df['Nest Father'].notna() &
        df['Genetic Father'].notna() &
        (df['Nest Father'] != '') &
        (df['Genetic Father'] != '') &
        (df['Nest Father'] != 'Unknown') &
        (df['Genetic Father'] != 'Unknown')
    ].copy()

    df = df.drop_duplicates(subset=['Bird Name', 'Nest Father', 'Genetic Father'])

    rows = []

    for nest_father, g_nest in df.groupby('Nest Father'):
        g_nest = g_nest.drop_duplicates(subset=['Bird Name'])

        hr_birds = g_nest[g_nest['Rearing Type'] == 'hr']['Bird Name'].tolist()
        hr_list = '; '.join(sorted(hr_birds)) if hr_birds else ''

        xf_only = g_nest[g_nest['Rearing Type'] == 'xf']

        for genetic_father, g_pair in xf_only.groupby('Genetic Father'):
            xf_birds = g_pair['Bird Name'].tolist()
            xf_list = '; '.join(sorted(xf_birds)) if xf_birds else ''

            hr_with = [b for b in hr_birds if b in found_set]
            hr_without = [b for b in hr_birds if b not in found_set]

            xf_with = [b for b in xf_birds if b in found_set]
            xf_without = [b for b in xf_birds if b not in found_set]

            rows.append({
                'Pair': f'{nest_father}-{genetic_father}',
                'Nest Father': nest_father,
                'Genetic Father': genetic_father,
                '# HR': len(hr_birds),
                '# XF': len(xf_birds),
                'HR Birds': hr_list,
                'XF Birds': xf_list,
                'Nest Father Song Found': nest_father in found_set,
                'Genetic Father Song Found': genetic_father in found_set,
                '# HR With Songs': len(hr_with),
                '# HR Without Songs': len(hr_without),
                'HR With Songs': '; '.join(sorted(hr_with)),
                'HR Without Songs': '; '.join(sorted(hr_without)),
                '# XF With Songs': len(xf_with),
                '# XF Without Songs': len(xf_without),
                'XF With Songs': '; '.join(sorted(xf_with)),
                'XF Without Songs': '; '.join(sorted(xf_without)),
            })

    pair_summary_df = pd.DataFrame(rows)

    if not pair_summary_df.empty:
        pair_summary_df = pair_summary_df.sort_values(
            by=['# XF', 'Nest Father', 'Genetic Father'],
            ascending=[False, True, True]
        ).reset_index(drop=True)

    return pair_summary_df

