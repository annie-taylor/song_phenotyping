# Song Phenotyping — project path configuration
#
# Copy this file to config.yaml and edit for your machine.
# config.yaml is gitignored so each machine keeps its own paths.
#
# Paths can use ~ for home directory or forward slashes on all platforms.
# Leave macaw_root as null to auto-detect (macOS: /Volumes/users,
# Windows: Z:\, Linux: SMB mount). Set it explicitly to override.

paths:
  # Root of local data cache (external drive or local SSD).
  # macOS:   /Volumes/Extreme SSD
  # Windows: E:/
  local_cache: /Volumes/Extreme SSD

  # Macaw server root — null = auto-detect
  macaw_root: null

  # Path to the SQLite run registry (relative to project root, or absolute).
  # Leave as default unless you want the DB somewhere specific.
  run_registry: db.sqlite3

# ---------------------------------------------------------------------------
# Pipeline run settings
# ---------------------------------------------------------------------------
# These are read by run_pipeline.py.  Any value set here can also be
# overridden by the ALL-CAPS constants at the top of run_pipeline.py
# (set them to a non-None value to override).
pipeline:
  # Where to write pipeline outputs — one subdirectory per bird.
  # macOS:   /Volumes/Extreme SSD/pipeline_runs
  # Windows: E:/pipeline_runs
  save_path: /Volumes/Extreme SSD/pipeline_runs

  # Parent directory that contains evsonganaly bird folders.
  # Each bird lives at <evsong_source>/<bird_id>/source/
  # macOS:   /Volumes/Extreme SSD/birds/evsong
  # Windows: E:/birds/evsong
  # Set to null to skip evsonganaly processing.
  evsong_source: /Volumes/Extreme SSD/birds/evsong

  # WhisperSeg metadata directory (bird folders under here).
  # Set to null to skip wseg processing.
  wseg_metadata: null

  # Which birds to process.
  # null  → auto-discover all birds found under evsong_source / wseg_metadata
  # list  → process only the named birds, e.g. [or18or24, bu78bu77]
  birds: null

  # Run name — the subdirectory under <bird>/runs/ that holds all stage outputs.
  # null = auto-compute an 8-char hex hash from all computational parameters.
  #        Changing any param produces a new directory; same params reuses it.
  # str  = pin a fixed name (e.g. "baseline") across all runs regardless of params.
  run_name: null

  # Maximum songs to process per bird (null = all songs).
  # Use a small number (e.g. 5–30) for quick smoke tests.
  songs_per_bird: 30

  # Random seed for song selection in Stage A.
  # null = non-deterministic (different songs each run if songs_per_bird < total).
  # Set an integer (e.g. 42) to always select the same subset.
  songs_seed: 42

  # Copy audio and metadata files from the source directory to save_path
  # before processing (true = local copy; false = read from source in place).
  #
  # Use true when:
  #   - Source audio lives on a network server (e.g. Macaw) and you want to
  #     process locally for speed or to work offline.
  #   - You are on a PC and the server drive may disconnect mid-run.
  #
  # On the first run with copy_locally: true, Stage A copies every file to
  # <save_path>/copied_data/<bird>/.  On subsequent runs with the same
  # save_path, the local cache is reused automatically — no server needed.
  #
  # Use false (default) when:
  #   - Source audio is already local (e.g. an external SSD mounted as evsong_source).
  #   - You are processing from a fast, reliable network share and copying is unnecessary.
  copy_locally: false

  # ---------------------------------------------------------------------------
  # Stage A — spectrogram parameters
  # ---------------------------------------------------------------------------
  # These control how syllable spectrograms are computed.
  # Defaults shown; omit a key to accept the default.
  spectrograms:
    nfft: 512
    hop: 1
    target_shape: [513, 300]    # [freq_bins, time_bins]
    min_freq: 400.0
    max_freq: 10000.0
    max_dur: 0.080              # maximum syllable duration in seconds
    fs: 32000.0                 # expected sample rate
    save_inst_freq: false       # append instantaneous-frequency channel
    save_group_delay: false     # append group-delay channel
    duration_feature_weight: 0.0  # 0 = disabled; ~1.0 weights duration as one time bin
    use_warping: false          # frequency-warping augmentation
    # Recompute and overwrite Stage A HDF5 files that already exist on disk.
    # false (default) skips files that are already present, making re-runs fast.
    # Set to true if source audio has changed or you need to force a clean rebuild.
    overwrite_existing: false

  # ---------------------------------------------------------------------------
  # Stage C — UMAP embedding parameters
  # ---------------------------------------------------------------------------
  embedding:
    # Default UMAP parameters (used when not doing a grid search)
    n_neighbors: 20
    min_dist: 0.5
    metric: euclidean
    n_components: 2
    # Seed for syllable subsampling when dataset exceeds memory limits
    subsample_seed: 42
    # Grid-search values — all combinations are tried; best is selected
    n_neighbors_grid: [5, 10, 20, 50, 100]
    min_dist_grid: [0.01, 0.05, 0.1, 0.3, 0.5]
    # Maximum parallel workers for Stage C UMAP grid search.
    # null = let the memory-aware adaptive calculation decide (recommended).
    # Set an integer (e.g. 4) to cap the worker count on machines with many CPUs.
    max_workers: null
    # Recompute and overwrite UMAP embedding files that already exist on disk.
    # false (default) skips parameter combinations whose .h5 file is already
    # present and compatible with the current data, making re-runs much faster.
    # Set to true if flattened features have changed or you want a clean rebuild.
    overwrite: false

  # ---------------------------------------------------------------------------
  # Stage D — labelling / clustering parameters
  # ---------------------------------------------------------------------------
  labelling:
    # Clustering evaluation metrics.  Supported: silhouette, dbi, ch, dunn, nmi.
    # 'ch' (Calinski-Harabasz) is excluded by default; re-add if desired.
    metrics: [silhouette, dbi]
    # Optional per-metric weights for the composite score.
    # Keys must match the metrics list.  Omit to use equal weights.
    # metric_weights:
    #   silhouette: 2.0
    #   dbi: 1.0
    replace_labels: false       # true = delete existing labels and re-cluster
    # HDBSCAN grid — null uses the built-in default (min_cluster_size ∈ [5,20,60],
    # min_samples ∈ [5,15], giving 6 combinations).
    hdbscan_grid: null
    # hdbscan_grid:             # custom grid example:
    #   min_cluster_size: [10, 30]
    #   min_samples: [5, 10]
    generate_cluster_pdf: false # true = write a PDF report of top clusterings
    # Maximum parallel workers for Stage D HDBSCAN parameter search.
    # null = all available CPUs (capped at number of parameter combinations).
    # Set an integer (e.g. 4) to limit CPU usage on shared machines.
    max_workers: null

  # ---------------------------------------------------------------------------
  # Stage E — phenotyping parameters
  # ---------------------------------------------------------------------------
  phenotyping:
    min_syllable_proportion: 0.02
    repeat_significance_threshold: 0.4
    dyad_threshold: 0.95
    use_top_n_clusterings: 3
    generate_plots: true        # write phenotype summary figures

  # ---------------------------------------------------------------------------
  # Catalog / output
  # ---------------------------------------------------------------------------
  generate_catalog: true        # write HTML catalogs to results/catalog/ after Stage E
